# Copy this file to .env and fill in your DATABASE_URL
# Local dev (Docker Postgres exposed on 5432):
# DATABASE_URL="postgresql://upsilon:upsilontaxpro@localhost:5432/upsilondb?schema=public"
#
# Inside Docker network (container-to-container):
# DATABASE_URL="postgresql://upsilon:upsilontaxpro@postgres:5432/upsilondb?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/upsilondb?schema=public"
