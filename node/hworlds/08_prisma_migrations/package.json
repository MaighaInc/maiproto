{
  "name": "taxpro-prisma-migrations",
  "version": "1.0.0",
  "description": "Standalone Prisma migration project for Upsilon TaxPro DB schema",
  "private": true,
  "scripts": {
    "migrate:dev": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset --force",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "init": "prisma migrate reset --force && prisma migrate dev --name init"
  },
  "devDependencies": {
    "prisma": "^6.3.1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
